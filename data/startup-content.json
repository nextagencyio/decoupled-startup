      "type": "paragraph.sidebyside",
      "values": {
        "eyebrow": "Supply Chain",
        "title": "Tackle your biggest emissions source: the supply chain",
        "content": "<p>For most companies, Scope 3 supply chain emissions represent 70-90% of their total carbon footprint. Verdant makes the hardest part of carbon accounting manageable with automated supplier engagement and AI-powered estimation models.</p>",
        "image": {
          "url": "https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=800&h=600&fit=crop&q=80",
          "alt": "Global supply chain network visualization"
        },
        "image_position": "left",
        "features": ["@supply-feature-1", "@supply-feature-2", "@supply-feature-3"],
        "cta_text": "Explore Supply Chain Solutions",
        "cta_url": "/product/supply-chain"
      }
    },
