    {
      "id": "sidebyside-how",
      "type": "paragraph.sidebyside",
      "values": {
        "eyebrow": "How It Works",
        "title": "From raw data to climate action in minutes",
        "content": "<p>Verdant's AI engine transforms your operational data into a complete carbon footprint — no spreadsheets, no consultants, no guesswork. Connect your systems, and our platform does the rest.</p>",
        "image": {
          "url": "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&h=600&fit=crop&q=80",
          "alt": "Dashboard showing carbon analytics and emissions data"
        },
        "image_position": "right",
        "features": ["@how-feature-1", "@how-feature-2", "@how-feature-3"],
        "cta_text": "See It in Action",
        "cta_url": "/about"
      }
    },
    {
      "id": "supply-feature-1",
