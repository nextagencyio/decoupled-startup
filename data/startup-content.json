      "type": "paragraph.feature_item",
      "values": { "icon": "Globe", "title": "Scope 3 Coverage", "description": "Full upstream and downstream emissions mapping across 15 categories" }
    },
    {
      "id": "supply-feature-3",
      "type": "paragraph.feature_item",
      "values": { "icon": "ShieldCheck", "title": "Audit-Ready Data", "description": "Every data point is traceable, verifiable, and ready for third-party assurance" }
    },
