        "icon": "BarChart3",
        "title": "Carbon Analytics",
        "description": "AI-powered emissions tracking across Scope 1, 2, and 3. Automatically ingest data from your ERP, supply chain, and operational systems.",
        "link_text": "Learn more",
        "link_url": "/product/analytics"
